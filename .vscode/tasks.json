{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend (Spring Boot)",
      "type": "shell",
      "command": "cd backend && mvn spring-boot:run -Dspring-boot.run.arguments=\"--server.address=0.0.0.0\"",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Frontend (Angular)",
      "type": "shell",
      "command": "cd frontend && npm run start -- --host 0.0.0.0 --port 4200",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Dev Servers",
      "dependsOn": ["Start Backend (Spring Boot)", "Start Frontend (Angular)"],
      "dependsOrder": "parallel"
    }
  ]
}
